<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ============ HEADER ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/serverBuildInfoText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Build: X.Y.Z (YYYY-MM-DD)"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:gravity="end"
                    android:paddingEnd="8dp"/>

                <Button
                    android:id="@+id/librariesInfoButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="INFO"
                    android:textSize="10sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@drawable/rounded_button_gray" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Music Server by Regis"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1976D2"
                android:gravity="center"/>
        </LinearLayout>

        <!-- ============ STATISTICHE SERVER ============ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:addStatesFromChildren="false"
                android:background="#FDF6DC"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="12dp"
                    android:text="📊 Statistiche Server"
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Stato:"
                        android:textColor="#666666"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/serverStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OFFLINE"
                        android:textColor="#F44336"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Uptime:"
                        android:textColor="#666666"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/uptimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0s"
                        android:textColor="#333333"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Richieste totali:"
                        android:textColor="#666666"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/totalRequestsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#333333"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Cache hits:"
                        android:textColor="#666666"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/cacheHitsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#333333"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Elementi in cache:"
                        android:textColor="#666666"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/cacheElementsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#333333"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Pulsanti controllo server -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/refreshStatsButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/rounded_button_blue"
                        android:text="🔄 Aggiorna"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/startStopServerButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/rounded_button_green"
                        android:text="▶️ Avvia Server"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ============ CRONOLOGIA CACHE ============ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FBF5D9"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="12dp"
                    android:text="🕒 Cronologia Cache"
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/cacheHistoryRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="300dp"
                    android:minHeight="100dp" />

                <Button
                    android:id="@+id/showAllCacheButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mostra tutte"
                    android:visibility="gone"
                    android:layout_marginTop="8dp"
                    android:layout_gravity="center_horizontal"/>

                <TextView
                    android:id="@+id/emptyCacheText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="24dp"
                    android:text="Nessun elemento in cache"
                    android:textColor="#999999"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== TINYDB DATABASE SECTION ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#1E1E1E"
            android:layout_marginTop="8dp">

            <!-- Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💾 DATABASE (TinyDB Compatible)"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:paddingBottom="8dp"/>

            <!-- Database Statistics -->
            <TextView
                android:id="@+id/databaseStatsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading statistics..."
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textColor="#CCCCCC"
                android:background="#2A2A2A"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Recent URLs Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🕐 Last 5 Extracted URLs"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

            <!-- Recent URLs RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recentURLsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2A2A2A"
                android:layout_marginBottom="12dp"
                android:maxHeight="300dp"
                android:scrollbars="vertical"/>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Export Button -->
                <Button
                    android:id="@+id/exportDatabaseButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📤 Esporta Database"
                    android:textSize="12sp"
                    android:backgroundTint="#4CAF50"
                    android:layout_marginEnd="8dp"/>

                <!-- Clean Button -->
                <Button
                    android:id="@+id/cleanDatabaseButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🧹 Pulisci Scaduti"
                    android:textSize="12sp"
                    android:backgroundTint="#FF9800"
                    android:layout_marginStart="8dp"/>

            </LinearLayout>

            <!-- Info Text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ℹ️ Il database viene salvato automaticamente e può essere esportato in formato compatibile con Kodular TinyDB"
                android:textSize="11sp"
                android:textColor="#888888"
                android:textStyle="italic"
                android:paddingTop="8dp"/>

        </LinearLayout>

        <!-- ==================== END TINYDB SECTION ==================== -->

        <!-- ============ IMPOSTAZIONI SERVER ============ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FDF6DB"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="12dp"
                    android:text="⚙️ Impostazioni Server"
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Server Address -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="8dp"
                    android:text="Indirizzo Server"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/serverAddressInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:drawable/edit_text"
                    android:inputType="text"
                    android:padding="12dp"
                    android:text="localhost"
                    android:textSize="14sp" />

                <!-- Server Port -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:text="Porta Server"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/serverPortInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:drawable/edit_text"
                    android:inputType="number"
                    android:padding="12dp"
                    android:text="8080"
                    android:textSize="14sp" />

                <!-- Device IP -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:text="IP Dispositivo"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/deviceIpText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#E3F2FD"
                    android:padding="12dp"
                    android:text="192.168.1.100"
                    android:textColor="#1976D2"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Cache Expiration -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:text="Scadenza Cache (minuti)"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/cacheExpirationInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:drawable/edit_text"
                    android:inputType="number"
                    android:padding="12dp"
                    android:text="30"
                    android:textSize="14sp" />

                <!-- Network Timeout -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:text="Timeout Rete (secondi)"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/networkTimeoutInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:drawable/edit_text"
                    android:inputType="number"
                    android:padding="12dp"
                    android:text="30"
                    android:textSize="14sp" />

                <!-- Auto-clear cache -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pulizia automatica cache"
                        android:textColor="#666666"
                        android:textSize="14sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/autoClearCacheSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <!-- Low power mode -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Modalità risparmio energetico"
                        android:textColor="#666666"
                        android:textSize="14sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/lowPowerModeSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false" />
                </LinearLayout>

                <!-- Save button -->
                <Button
                    android:id="@+id/saveSettingsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/rounded_button_background"
                    android:text="💾 Salva Impostazioni"
                    android:textSize="14sp" />

                <!-- Nuovo pulsante per l'aggiornamento -->
                <Button
                    android:id="@+id/updateAppButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/rounded_button_purple"
                    android:text="⬆️ Aggiorna App"
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ============ PULSANTI AZIONI ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="16dp">

            <Button
                android:id="@+id/testVideoButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="🎬 Test Video"
                android:textSize="14sp"
                android:background="@drawable/rounded_button_purple"/>

            <Button
                android:id="@+id/clearCacheButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🗑️ Pulisci Cache"
                android:textSize="14sp"
                android:background="@drawable/rounded_button_red"/>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
