<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#16E91E1E"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Titolo del video -->
        <TextView
            android:id="@+id/cacheVideoName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Video Name"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Riga scadenza -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏱️ URL generata da Youtube scade tra:"
                android:textColor="#666666"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/cacheExpireTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25m 30s"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ID del video -->
        <TextView
            android:id="@+id/cacheVideoId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:text="ID: dQw4w9WgXcQ"
            android:textColor="#999999"
            android:textSize="11sp" />

        <!-- 👇 Nuovo: contatore accessi -->
        <TextView
            android:id="@+id/cacheAccessCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:text="Accessi: 0"
            android:textColor="#2196F3"
            android:textSize="11sp"
            android:textStyle="italic" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
