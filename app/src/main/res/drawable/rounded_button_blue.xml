<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="18dp"/> <!-- Raggio leggermente più piccolo -->
            <solid android:color="#B0BEC5"/> <!-- Grigio più scuro quando premuto -->
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp"/>
            <solid android:color="#90A4AE"/> <!-- Grigio di default -->
        </shape>
    </item>
</selector>
